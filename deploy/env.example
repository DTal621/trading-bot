# Copy to /opt/sentiment_bot/.env (chmod 600). Never commit real keys.
ALPACA_API_KEY=your_paper_key
ALPACA_API_SECRET=your_paper_secret
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
# ANTHROPIC_API_KEY only if the instance itself runs the LLM review
# (otherwise the daily review runs in GitHub Actions). Setting this also makes
# any Claude Code session on this box bill the API instead of your plan.
# ANTHROPIC_API_KEY=
